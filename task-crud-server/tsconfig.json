{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": true,
    "lib": ["esnext"],
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "target": "ES2022",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}